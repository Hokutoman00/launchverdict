# LaunchVerdict — environment. The app + /demo run with NONE of these set
# (demo uses seeded data). These light up the live closed loop.

# Telemetry store (Vercel Postgres / Neon). Set automatically by the Vercel
# Neon integration; locally use your Neon connection string.
POSTGRES_URL=

# GitHub: a fine-grained token or App installation token with repo read +
# pull_request:write + commit status:write on the connected repo.
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=

# Novus PR review-comment author login (the bot that posts UX flags).
NOVUS_BOT_LOGIN=novus-ai

# LLM prose polish (optional; verdict call is deterministic without it).
ANTHROPIC_API_KEY=

# Public origin used to build verdict-card links in PR comments.
PUBLIC_BASE_URL=

# Demo/short-cycle: shrink the before/after window so a verdict matures in
# minutes instead of 7 days (ms). Leave unset for the real 7-day window.
VERDICT_WINDOW_MS=
